APP_ENV=development

# Security
SECRET_KEY=super-secret-key
MCP_TOKEN=change_me_mcp_token
DEFAULT_LOCALE=zh-CN

# Bootstrap admin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=123456

# PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:123456@localhost:5432/home_monitor

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
VIDEO_ROOT_PATH=/data/videos
PLAYBACK_CACHE_ROOT=/data/hls

# DB bootstrap retry
DB_INIT_MAX_RETRIES=120
DB_INIT_RETRY_INTERVAL_SECONDS=2
